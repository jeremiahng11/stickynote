<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/font.css">
    <link rel="stylesheet" href="/css/all.min.css">
	<link rel="stylesheet" href="/css/style.css?v=<%= assetVersion %>">
	<link rel="shortcut icon" type="image/ico" href="/images/favicon.png" />
    <title>Reset Password</title>
  </head>
  <body>
	<div class="welcome_wrapper">
		<div class="welcome_holder">
			<div class="log_reg_form_wrapper">
				<div class="welcome_logo_wrap">
					<img class="logo" src="/images/Sticky-Notes-logo.png" alt="" />
					<h4 class="welcome_title">Choose a new password</h4>
				</div>
				<% if (valid) { %>
				<div class="forgot_pws_wrap">
					<form id="resetForm">
						<input type="hidden" id="reset_token" value="<%= token %>"/>
						<div class="input_wrap">
							<input type="password" placeholder="New password" id="reset_password"/>
							<i class="fas fa-unlock-alt"></i>
						</div>
						<div class="input_wrap">
							<input type="password" placeholder="Confirm new password" id="reset_cpassword"/>
							<i class="fas fa-unlock-alt"></i>
						</div>
						<button type="button" class="button" id="resetBtn">Update password</button>
						<br><br>
						<div class="note_forgot_pws_link"><a href="/">Back to login</a></div>
					</form>
				</div>
				<% } else { %>
				<div class="forgot_pws_wrap">
					<p>This reset link is invalid or has expired.</p>
					<div class="note_forgot_pws_link"><a href="/forgot-password">Request a new link</a></div>
				</div>
				<% } %>
			</div>
		</div>
	</div>

	<!-- Toaster alert -->
	<div class="alert_close note_alert_wrapper msg">
		<div class="note_alert_inner">
			<div class="note_alert_icon"></div>
			<p class="alert_text"></p>
		</div>
	</div>

	<script src="/js/jquery.min.js"></script>
	<script src="/js/bootstrap.min.js"></script>
	<script src="/js/script.js?v=<%= assetVersion %>"></script>
	<% if (valid) { %>
	<script>
		document.getElementById('resetBtn').addEventListener('click', function(){
			var pw = document.getElementById('reset_password').value;
			var cpw = document.getElementById('reset_cpassword').value;
			if(pw.length < 6){ isValid('error', 'Password must be at least 6 characters.'); return; }
			if(pw !== cpw){ isValid('error', 'Passwords do not match.'); return; }
			var token = document.getElementById('reset_token').value;
			var xhttp = new XMLHttpRequest();
			xhttp.onreadystatechange = function(){
				if(this.readyState == 4 && this.status == 200){
					var res = JSON.parse(this.responseText);
					isValid(res.status ? 'ok' : 'error', res.message);
					if(res.status){ setTimeout(function(){ window.location.href = '/'; }, 1000); }
				}
			};
			xhttp.open('post', '/reset-password', true);
			xhttp.setRequestHeader('content-type', 'application/x-www-form-urlencoded');
			xhttp.send('token=' + encodeURIComponent(token) + '&password=' + encodeURIComponent(pw));
		});
	</script>
	<% } %>
	</body>
</html>
