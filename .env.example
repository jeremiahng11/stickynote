# --- Server ---
PORT=3005
HOST=0.0.0.0
SESSION_SECRET=change-me-to-a-long-random-string
# set to true when served over HTTPS behind a proxy (Coolify)
COOKIE_SECURE=false
CORS_ORIGIN=*

# --- Database (MySQL / MariaDB) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=stickynotes

# --- SMTP (used for the forgot-password email) ---
SMTP_SERVICE=
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
EMAIL_FROM=
EMAIL_PASS=
EMAIL_TEXT=Password for Sticky Notes
EMAIL_SUBJECT=Password change request
