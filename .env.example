# --- Server ---
PORT=3005
HOST=0.0.0.0
SESSION_SECRET=change-me-to-a-long-random-string
# set to true when served over HTTPS behind a proxy (Coolify)
COOKIE_SECURE=false
# public base URL, used to build password-reset links (falls back to the request host)
BASE_URL=
# set SIGNUP=0 to disable new registrations
SIGNUP=1

# --- Database (MySQL / MariaDB) ---
# Either set a single DATABASE_URL (e.g. the internal URL Coolify provides)...
# DATABASE_URL=mysql://user:password@host:3306/dbname
# ...or the discrete variables below. DATABASE_URL takes precedence.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=stickynotes
# set to true if the database requires TLS (e.g. require_secure_transport=ON)
DB_SSL=false

# --- SMTP (used to send the password-reset link) ---
SMTP_SERVICE=
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
EMAIL_FROM=
EMAIL_PASS=
EMAIL_SUBJECT=Reset your Sticky Notes password
